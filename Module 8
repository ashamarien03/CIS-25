int main()
{
    const int MAX_SIZE = 100;
    Patient* patients = new Patient[MAX_SIZE];

    // Preloaded patient data
    int count = 5;

    patients[0] = {1001, "Fin", 42, "Male", "Flu"};
    patients[1] = {1002, "Jake", 30, "Male", "Migraine"};
    patients[2] = {1003, "Princess Bubblegum", 55, "Female", "Diabetes"};
    patients[3] = {1004, "Marceline", 28, "Female", "Asthma"};
    patients[4] = {1005, "BMO", 60, "Male", "Hypertension"};

    int choice;

    do
    {
        cout << "\nHospital Patient System\n";
        cout << "1. Add Patient\n";
        cout << "2. Display Patients\n";
        cout << "3. Search Patient\n";
        cout << "4. Update Patient\n";
        cout << "5. Save Patients\n";
        cout << "6. Exit\n";
        cout << "Enter choice: ";
        cin >> choice;

        switch (choice)
        {
            case 1:
                addPatient(patients, count, MAX_SIZE);
                break;
            case 2:
                displayPatients(patients, count);
                break;
            case 3:
                searchPatient(patients, count);
                break;
            case 4:
                updatePatient(patients, count);
                break;
            case 5:
                savePatients(patients, count);
                break;
            case 6:
                cout << "Good Bye!\n";
                break;
            default:
                cout << "Invalid choice.\n";
        }

    } while (choice != 6);

    delete[] patients;
    return 0;
}

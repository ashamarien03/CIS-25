    if (!outFile)
    {
        cout << "Error opening file.\n";
        return;
    }

    for (int i = 0; i < count; i++)
    {
        outFile << patients[i].id << " "
                << patients[i].name << " "
                << patients[i].age << " "
                << patients[i].gender << " "
                << patients[i].diagnosis << endl;

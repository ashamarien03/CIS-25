#include <iostream>
#include <fstream>
#include <string>
#include <iomanip>

using namespace std;

class Item {
public:
    string name;
    double price;
    int quantity;

    double getTotalPrice() {
        return price * quantity;
    }
};

void showSuggestions() {
    cout << "\nPopular items (example prices):\n";
    cout << "  Milk        $3.99\n";
    cout << "  Eggs        $4.29\n";
    cout << "  Bread       $3.50\n";
    cout << "  Apples      $1.25\n";
    cout << "  Chicken     $7.99\n";
    cout << "  Rice        $5.49\n";
    cout << "  Pasta       $2.19\n";
    cout << "  Coffee      $9.99\n";
    cout << "  Yogurt      $1.49\n";
    cout << "  Cheese      $5.79\n\n";
}

void addItem() {
    Item item;

    showSuggestions();

    cout << "Enter item name: ";
    cin >> item.name;

    cout << "Enter item price: ";
    cin >> item.price;

    cout << "Enter item quantity: ";
    cin >> item.quantity;

    ofstream outFile("cart.txt", ios::app);

    if (outFile.is_open()) {
        outFile << item.name << " " << item.price << " " << item.quantity << endl;
        outFile.close();
        cout << "Item added to cart.\n";
    } else {
        cout << "Error opening file.\n";
    }
}

void viewCheckout() {
    ifstream inFile("cart.txt");
    Item item;
    double grandTotal = 0;

    if (!inFile.is_open()) {
        cout << "No cart found.\n";
        return;
    }

    cout << "\n===== CHECKOUT =====\n";

    cout << fixed << setprecision(2);

    while (inFile >> item.name >> item.price >> item.quantity) {
        double total = item.getTotalPrice();
        grandTotal += total;

        cout << item.name << " - $"
             << item.price << " x "
             << item.quantity << " = $"
             << total << endl;
    }

    cout << "---------------------\n";
    cout << "Total: $" << grandTotal << endl;

    inFile.close();
}

int main() {
    int choice;

    do {
        cout << "\n===== SHOPPING CART MENU =====\n";
        cout << "1. Add item to cart\n";
        cout << "2. View checkout\n";
        cout << "3. Exit\n";
        cout << "Choose an option: ";
        cin >> choice;

        switch (choice) {
            case 1:
                addItem();
                break;
            case 2:
                viewCheckout();
                break;
            case 3:
                cout << "Thank you for shopping!\n";
                break;
            default:
                cout << "Invalid option. Try again.\n";
        }

    } while (choice != 3);

    return 0;
}
